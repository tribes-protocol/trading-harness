{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"],
      "@shared/*": ["./src/*"]
    }
  },
  "include": ["src/**/*.ts", ".pi/extensions/**/*.ts"],
  "exclude": ["node_modules", "runtime", ".pi/skills"]
}
