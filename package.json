{
  "name": "pi-research-platform",
  "version": "0.1.0",
  "description": "Institutional multi-asset investment research platform for the Pi harness",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
