{
  "name": "trading-harness",
  "version": "1.0.0",
  "description": "Autonomous Hyperliquid trading harness for Pi (standalone)",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "bun run typecheck",
    "dev": "sh scripts/dev.sh",
    "setup:dev": "sh scripts/setup-env.sh dev",
    "setup:prod": "sh scripts/setup-env.sh prod",
    "test": "bun run typecheck",
    "lint": "eslint . --ext .ts,.mts --max-warnings 0 --no-warn-ignored",
    "lint:fix": "eslint . --ext .ts,.mts --fix --max-warnings 0 --no-warn-ignored",
    "format": "prettier --write \"**/*.{ts,mts,md,json,jsonc,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,mts,md,json,jsonc,yml,yaml}\"",
    "knip": "knip"
  },
  "dependencies": {
    "@nktkas/hyperliquid": "0.32.2",
    "@privy-io/node": "0.7.0",
    "@solana/spl-token": "0.4.14",
    "@solana/web3.js": "1.98.4",
    "bignumber.js": "9.3.1",
    "bs58": "4.0.1",
    "commander": "14.0.3",
    "jose": "4.15.9",
    "viem": "2.46.3",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "0.80.3",
    "@earendil-works/pi-tui": "0.80.3",
    "@eslint/js": "9.39.3",
    "@types/bs58": "4.0.1",
    "@types/node": "20.17.6",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "@vitest/coverage-v8": "4.1.3",
    "eslint": "9.39.3",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prettier": "5.5.3",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-unused-imports": "4.4.1",
    "knip": "5.44.0",
    "prettier": "3.3.3",
    "typescript": "5.8.3",
    "vitest": "4.1.3"
  }
}
