# Tribes trading harness — environment template.
# Copy to `.env` and fill in real values. `.env` is gitignored; never commit secrets.
# The compiled `tribes-cli` auto-loads `.env`. Skills that call provider APIs directly
# read these same keys from `.env` (see docs/inlined-provider-apis.md).

# --- Core runtime -----------------------------------------------------------
# Leave NODE_ENV unset/empty or "production" to use the hardcoded prod API_BASE_URL
# and PRIVY_APP_ID. Set a non-production value only for local backend dev.
NODE_ENV=
# Only read (and required) under a non-production NODE_ENV.
PRIVY_APP_ID=
# Bearer for the Tribes API proxy. Normally minted by `tribes-cli login`
# (or injected as TRIBES_API_KEY inside a sandbox).
API_BEARER_TOKEN=
# Never read from env in production (hardcoded). Set only for local dev.
API_BASE_URL=

# --- Analyst data providers (direct-API skills) -----------------------------
# BirdEye — on-chain token/pair/wallet data. Header: X-API-KEY, plus x-chain per call.
# Base: https://public-api.birdeye.so
BIRDEYE_API_KEY=

# Nansen — smart-money, TokenGodMode, profiler. Header: apiKey (POST JSON).
# Base: https://api.nansen.ai
NANSEN_API_KEY=

# CoinGecko Pro — coin fundamentals, market-wide aggregates, GeckoTerminal on-chain pools,
# exchanges/derivatives/treasury. Header: x-cg-pro-api-key.
# Base: https://pro-api.coingecko.com
COIN_GECKO_PRO_API_KEY=

# FRED (St. Louis Fed) — macro series (DXY, yields, VIX, CPI, ...). Query: api_key.
# Base: https://api.stlouisfed.org
FRED_API_KEY=

# NewsData.io — market/crypto/latest news search. Query: apikey.
# Base: https://newsdata.io
NEWSDATAIO_API_KEY=

# Moralis — ERC-20 token metadata & price. Header: X-API-Key.
# Base: https://deep-index.moralis.io
MORALIS_API_KEY=

# Alchemy — EVM JSON-RPC (native/ERC-20 balance reads). Key is embedded in the URL:
# https://<network>-mainnet.g.alchemy.com/v2/<ALCHEMY_API_KEY>
# Networks: eth, base, bnb, arb, avax, opt, polygon, unichain, sonic.
ALCHEMY_API_KEY=

# Helius — Solana JSON-RPC (SOL/SPL balance reads). Key is a query param:
# https://mainnet.helius-rpc.com/?api-key=<HELIUS_API_KEY>
HELIUS_API_KEY=

# Marketstack — stock/equity data (stock-analyst). Query: access_key.
MARKETSTACK_API_KEY=
