# Provider API credentials — copy to .env and fill in. NEVER commit .env.
# All keys are optional: adapters whose key is absent are reported as
# "not configured" by `pi doctor` and excluded from live routing.

ALCHEMY_API_KEY=
HELIUS_API_KEY=
MORALIS_API_KEY=
BIRDEYE_API_KEY=
COINGECKO_PRO_API_KEY=
NANSEN_API_KEY=
MARKETSTACK_API_KEY=
FRED_API_KEY=
NEWSDATA_API_KEY=
TAVILY_API_KEY=

# Platform settings
# LOG_LEVEL=info            # debug | info | warn | error
# PI_CACHE_DIR=.cache       # disk cache location (respects provider storage restrictions)
# PI_HTTP_TIMEOUT_MS=15000  # default per-request timeout
