{
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "eslint.codeActionsOnSave.rules": [
    "!unused-imports/no-unused-imports",
    "!unused-imports/no-unused-vars",
    "*"
  ],
  "files.exclude": {
    ".adal": true,
    ".agents": true,
    ".aider-desk": true,
    ".augment": true,
    ".autohand": true,
    ".bob": true,
    ".claude": true,
    ".codeartsdoer": true,
    ".codebuddy": true,
    ".codemaker": true,
    ".codestudio": true,
    ".commandcode": true,
    ".continue": true,
    ".cortex": true,
    ".crush": true,
    ".devin": true,
    ".factory": true,
    ".forge": true,
    ".goose": true,
    ".hermes": true,
    ".iflow": true,
    ".inferencesh": true,
    ".jazz": true,
    ".junie": true,
    ".kilocode": true,
    ".kiro": true,
    ".kode": true,
    ".lingma": true,
    ".mcpjam": true,
    ".moxby": true,
    ".mux": true,
    ".neovate": true,
    ".ona": true,
    ".openhands": true,
    ".pochi": true,
    ".qoder": true,
    ".qwen": true,
    ".reasonix": true,
    ".roo": true,
    ".rovodev": true,
    ".tabnine": true,
    ".terramind": true,
    ".tinycloud": true,
    ".trae": true,
    ".vibe": true,
    ".windsurf": true,
    ".zencoder": true,
    "agent": true,
    "data": true,
    "skills": true,
    "node_modules": true
  }
}
